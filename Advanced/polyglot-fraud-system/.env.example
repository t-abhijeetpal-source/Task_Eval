# A3 Polyglot Fraud System — environment template.
# Copy to `.env` and source it, or export these before running the stack.
#   cp .env.example .env && set -a && . ./.env && set +a

# -- REQUIRED: internal scoring callback auth (A5-2 / A5-17) ------------------
# The /internal/transactions/{id}/score endpoint is FAIL-CLOSED: with no token
# configured it denies ALL callers (503). The FastAPI service and the Node
# worker MUST share the SAME value or the worker's callback gets 401.
# Generate a strong one:  openssl rand -hex 32
A3_INTERNAL_TOKEN=dev-token-change-me

# -- OPTIONAL: public ingestion key (A3-012) ---------------------------------
# Unset = demo mode, POST /transactions is open. When set, every ingest must
# send a matching `X-API-Key` header. NOT fail-closed (unset is valid demo).
# A3_API_KEY=

# -- FastAPI service ---------------------------------------------------------
QUEUE_DIR=./queue
DATABASE_URL=sqlite:///./data/a3.db

# -- Node worker -------------------------------------------------------------
API_URL=http://localhost:8000
ENGINE_BIN=../rust-engine/target/release/fraud-engine
# ENGINE_TIMEOUT_MS=5000          # A5-7: kill a hung engine (default 5000)
# MAX_OUTPUT_BYTES=1048576        # A5-10: cap engine stdout (default 1 MiB)
