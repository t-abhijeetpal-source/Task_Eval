# A1 parallel-repo-analysis — environment template.
# Copy to .env (`cp .env.example .env`) and fill in. .env is git-ignored.

# Absolute path to the analyzed repository (the Paytm Money android-monorepo).
# Optional for `run_a1_analysis.sh --validate-only` and CI validation.
# Required only for live evidence capture (scripts/capture_evidence.sh).
TARGET_REPO=

# Optional: pin the analyzed commit for provenance. If unset and TARGET_REPO is a
# git repo, scripts derive it via `git -C "$TARGET_REPO" rev-parse HEAD`.
# TARGET_COMMIT=
