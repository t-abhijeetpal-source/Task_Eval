# Reproducible local environment variables for the monorepo services.
# `make setup-env` copies this to `.env` (without overwriting an existing one).
# Apps read these from the process environment (set by docker-compose / uvicorn /
# the worker). Override locally by editing .env; never commit real secrets.

# --- Database (A2 / A3 / D2 services) ---
DATABASE_URL=postgresql://appuser:apppass@localhost:5432/appdb

# --- Job queue + worker (A3 / D2) ---
QUEUE_DIR=./queue
API_URL=http://localhost:8080
ENGINE_BIN=./rust-engine/target/release/fraud-engine
WORKER_ID=worker-1
POLL_INTERVAL=1

# --- Service ports ---
PORT=8000

# --- A3 internal callback auth (optional; when set, /internal requires this token) ---
A3_INTERNAL_TOKEN=
